# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored — never commit it.

# ECR repository URI: <account-id>.dkr.ecr.<region>.amazonaws.com/<repo-name>
IMAGE_REPOSITORY=

# Amplify app ID (from: aws amplify create-app --query 'app.appId' --output text)
AMPLIFY_APP_ID=

# API Gateway URL from backend deploy output — baked into the frontend bundle at build time
# Example: https://<id>.execute-api.us-east-1.amazonaws.com/api
VITE_API_URL=

# Allowed CORS origin for the Lambda API — set to your Amplify branch URL
# Format: https://main.<AMPLIFY_APP_ID>.amplifyapp.com
CORS_ORIGINS=
